# Coverage configuration for CI gating coverage (line-only).
#
# This keeps `branch = False` so the gate measures line coverage, not
# branch coverage. Branch coverage is still useful for deeper analysis,
# but enforcing 90% total (line+branch) on the full repo is too strict.
#
# Excludes modules that are integration/data-layer style and not expected to
# reach unit-test branch coverage in CI.

[run]
relative_files = True
branch = False

[paths]
source =
    autoppia_iwa
    */autoppia_iwa

[report]
omit =
    */__init__.py
    */conftest.py
    */tests/*
    */test_*.py
    autoppia_iwa/entrypoints/benchmark/benchmark.py
    autoppia_iwa/entrypoints/benchmark/run.py
    autoppia_iwa/entrypoints/benchmark/config.py
    autoppia_iwa/entrypoints/evaluation/client.py
    autoppia_iwa/entrypoints/evaluation/endpoint.py
    autoppia_iwa/entrypoints/judge_benchmark/**
    autoppia_iwa/entrypoints/judge_benchmark_endpoint/**
    autoppia_iwa/entrypoints/technical_test_agent/**
    autoppia_iwa/entrypoints/test_task.py
    autoppia_iwa/entrypoints/test_your_agent/**
    autoppia_iwa/entrypoints/web_verification/**

    # Demo_webs project generation/data layers (not gated)
    autoppia_iwa/src/demo_webs/projects/autobooks_2/generation_functions.py
