# Coverage configuration for CI gating coverage (line-only).
#
# This keeps `branch = False` so the gate measures line coverage, not
# branch coverage. Branch coverage is still useful for deeper analysis,
# but enforcing 90% total (line+branch) on the full repo is too strict.
#
# Excludes modules that are integration/data-layer style and not expected to
# reach unit-test branch coverage in CI.

[run]
relative_files = True
branch = False

[paths]
source =
    autoppia_iwa
    */autoppia_iwa

[report]
omit =
    */__init__.py
    */conftest.py
    */tests/*
    */test_*.py
    autoppia_iwa/entrypoints/benchmark/benchmark.py
    autoppia_iwa/entrypoints/benchmark/run.py
    autoppia_iwa/entrypoints/benchmark/config.py
    autoppia_iwa/entrypoints/evaluation/client.py
    autoppia_iwa/entrypoints/evaluation/endpoint.py
    autoppia_iwa/entrypoints/judge_benchmark/**
    autoppia_iwa/entrypoints/judge_benchmark_endpoint/**
    autoppia_iwa/entrypoints/technical_test_agent/**
    autoppia_iwa/entrypoints/test_task.py
    autoppia_iwa/entrypoints/test_your_agent/**
    autoppia_iwa/entrypoints/web_verification/**
    autoppia_iwa/src/demo_webs/web_verification/**
    autoppia_iwa/src/web_agents/examples/**

    # Demo_webs project generation/data layers (not gated)
    autoppia_iwa/src/demo_webs/projects/*/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/*/replace_functions.py

    # Demo_webs project dataset helpers that are not unit-covered
    autoppia_iwa/src/demo_webs/projects/*/data_utils.py

    # Static/derivation layers
    autoppia_iwa/src/demo_webs/projects/*/data.py
    autoppia_iwa/src/demo_webs/projects/*/use_cases.py

    # Backend event definitions + trajectory registries (large, integration-style; not gate targets)
    autoppia_iwa/src/demo_webs/projects/*/events.py
    autoppia_iwa/src/demo_webs/projects/*/trajectories.py
    autoppia_iwa/src/demo_webs/projects/*/data_extraction_trajectories.py

    # Legacy / alternate layout (keep if present in forks)
    autoppia_iwa/src/demo_webs/projects/autodiscord_16/events.py
    autoppia_iwa/src/demo_webs/projects/autodiscord_16/generation_functions.py

    # Additional gate exclusions (keep the gate focused).
    autoppia_iwa/src/demo_webs/projects/p02_autobooks/utils.py
    autoppia_iwa/src/demo_webs/utils.py
    autoppia_iwa/src/demo_webs/classes.py
    autoppia_iwa/src/demo_webs/projects/shared_utils.py
    autoppia_iwa/src/demo_webs/projects/data_provider.py
    autoppia_iwa/src/demo_webs/projects/autocinema_1/generation_functions.py

    autoppia_iwa/src/evaluation/legacy/**
    autoppia_iwa/src/evaluation/stateful_evaluator/evaluator.py
    autoppia_iwa/src/evaluation/shared/utils.py
    autoppia_iwa/src/shared/visualizator.py
    autoppia_iwa/src/shared/web_utils.py
    autoppia_iwa/src/shared/web_voyager_utils.py
    autoppia_iwa/src/web_agents/apified_one_shot_agent.py
    autoppia_iwa/src/llms/service.py
    autoppia_iwa/src/data_generation/tasks/simple/simple_task_generator.py
    autoppia_iwa/src/data_generation/tasks/multi_step/multi_step_task_generator.py

    # Playwright/browser wiring (covered by integration / manual runs, not unit gate)
    autoppia_iwa/src/execution/playwright_browser_executor.py
    autoppia_iwa/src/execution/actions/browser_tools.py
