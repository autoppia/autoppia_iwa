# Coverage configuration for pytest-cov and SonarCloud.
# relative_files = True ensures paths in coverage.xml are relative to repo root,
# so sonar.coverage.exclusions in sonar-project.properties can match and exclude
# untested entrypoints/demo code from the coverage metric.
# branch = True enables branch coverage so SonarCloud shows accurate branch metrics.
# omit = exclude these from the run entirely so TOTAL and % only count testable code.
[run]
relative_files = True
branch = True

[paths]
source =
    autoppia_iwa
    */autoppia_iwa

[report]
omit =
    */tests/*
    */test_*.py
    */conftest.py
    */__init__.py
    autoppia_iwa/entrypoints/benchmark/benchmark.py
    autoppia_iwa/entrypoints/benchmark/run.py
    autoppia_iwa/entrypoints/benchmark/config.py
    autoppia_iwa/entrypoints/evaluation/client.py
    autoppia_iwa/entrypoints/evaluation/endpoint.py
    autoppia_iwa/entrypoints/judge_benchmark/*
    autoppia_iwa/entrypoints/judge_benchmark/**
    autoppia_iwa/entrypoints/judge_benchmark_endpoint/*
    autoppia_iwa/entrypoints/judge_benchmark_endpoint/**
    autoppia_iwa/entrypoints/technical_test_agent/*
    autoppia_iwa/entrypoints/technical_test_agent/**
    autoppia_iwa/entrypoints/test_task.py
    autoppia_iwa/entrypoints/test_your_agent/*
    autoppia_iwa/entrypoints/test_your_agent/**
    autoppia_iwa/entrypoints/web_verification/*
    autoppia_iwa/entrypoints/web_verification/**
    # Exclude demo_webs generation/replace from coverage except autocinema_1
    autoppia_iwa/src/demo_webs/projects/autobooks_2/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autobooks_2/replace_functions.py
    autoppia_iwa/src/demo_webs/projects/autozone_3/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autozone_3/replace_functions.py
    autoppia_iwa/src/demo_webs/projects/autocalendar_11/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autoconnect_9/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autocrm_5/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autodelivery_7/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autodining_4/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autodrive_13/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autohealth_14/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autolist_12/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autolodge_8/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/automail_6/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autostats_15/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/autowork_10/generation_functions.py
