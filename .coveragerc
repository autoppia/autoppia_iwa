# Coverage configuration for pytest-cov and SonarCloud

[run]
# Use relative paths so coverage.xml paths match Sonar
relative_files = True
branch = True

[paths]
source =
    autoppia_iwa
    */autoppia_iwa

[report]
# Exclude test files and untestable/demo files from coverage
omit =
    */__init__.py
    */conftest.py
    */tests/*
    */test_*.py
    autoppia_iwa/entrypoints/benchmark/benchmark.py
    autoppia_iwa/entrypoints/benchmark/run.py
    autoppia_iwa/entrypoints/benchmark/config.py
    autoppia_iwa/entrypoints/evaluation/client.py
    autoppia_iwa/entrypoints/evaluation/endpoint.py
    autoppia_iwa/entrypoints/judge_benchmark/**
    autoppia_iwa/entrypoints/judge_benchmark_endpoint/**
    autoppia_iwa/entrypoints/technical_test_agent/**
    autoppia_iwa/entrypoints/test_task.py
    autoppia_iwa/entrypoints/test_your_agent/**
    autoppia_iwa/entrypoints/web_verification/**
    autoppia_iwa/src/demo_webs/web_verification/**
    autoppia_iwa/src/web_agents/examples/**
    autoppia_iwa/src/demo_webs/projects/p02_autobooks/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p02_autobooks/replace_functions.py
    autoppia_iwa/src/demo_webs/projects/p03_autozone/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p03_autozone/replace_functions.py
    autoppia_iwa/src/demo_webs/projects/p05_autocrm/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p06_automail/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p07_autodelivery/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p08_autolodge/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p09_autoconnect/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p10_autowork/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p11_autocalendar/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p12_autolist/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p13_autodrive/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p14_autohealth/generation_functions.py
    autoppia_iwa/src/demo_webs/projects/p15_autostats/generation_functions.py

    # Demo_webs project modules that are not covered by unit tests
    # (or that primarily fetch/transform backend datasets).
    autoppia_iwa/src/demo_webs/projects/p01_autocinema/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p02_autobooks/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p03_autozone/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p04_autodining/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p05_autocrm/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p06_automail/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p07_autodelivery/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p08_autolodge/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p09_autoconnect/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p10_autowork/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p11_autocalendar/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p12_autolist/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p13_autodrive/data_utils.py
    autoppia_iwa/src/demo_webs/projects/p15_autostats/data_utils.py

    # Static/derivation layers
    autoppia_iwa/src/demo_webs/projects/*/data.py
    autoppia_iwa/src/demo_webs/projects/*/use_cases.py

    # Discord project is currently not exercised by tests.
    autoppia_iwa/src/demo_webs/projects/autodiscord_16/events.py
    autoppia_iwa/src/demo_webs/projects/autodiscord_16/generation_functions.py
